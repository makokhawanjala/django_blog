# Django Core
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-railway-domain.up.railway.app,yourdomain.com

# CSRF (add all domains you use)
CSRF_TRUSTED_ORIGINS=https://your-railway-domain.up.railway.app,https://yourdomain.com

# Database (Railway PostgreSQL — copy from Railway dashboard)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Anthropic Claude API
# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# YouTube Data API v3
# Get from console.cloud.google.com
YOUTUBE_API_KEY=AIza...

# Reddit API
# Create an app at apps.reddit.com
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=machiavellimind/1.0 by your-reddit-username

# Google Analytics (optional — for weekly digest pipeline)
# Service account JSON key path or property ID
GOOGLE_ANALYTICS_PROPERTY_ID=properties/your-property-id

# Email Notifications
NOTIFICATION_EMAIL=you@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
